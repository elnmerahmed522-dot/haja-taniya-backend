{
    # إيقاف الـ TLS التلقائي والـ HTTPS Redirect تماماً
    auto_https off

    # إيقاف الـ Admin API (مش محتاجينه في Production)
    admin off
}

http://:80 {
    root * /app/public

    # إخبار Caddy يثق في جميع الـ Proxies اللي أمامه (Railway)
    trusted_proxies static private_ranges

    php_server

    log {
        output stdout
        format json
    }
}